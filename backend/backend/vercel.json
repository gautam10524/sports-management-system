{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/static/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/static/js/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/static/images/$1"
    },
    {
      "src": "/fonts/(.*)",
      "dest": "/static/fonts/$1"
    },
    {
      "src": "/(.*).html",
      "dest": "/static/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ]
}
